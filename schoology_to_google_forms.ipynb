   "source": [
    "# 📚 Schoology → Google Forms Quiz Converter\n",
    "\n",
    "**Instructions for teachers:**\n",
    "1. Download your quiz as a `.imscc` file from Schoology\n",
    "2. Run **Step 1** to install dependencies\n",
    "3. Run **Step 2** to upload your `.imscc` file\n",
    "4. Run **Step 3** to extract and preview the questions\n",
    "5. Run **Step 4** to download the output files\n",
    "6. Import the CSV into Google Forms using the instructions at the bottom\n",
    "\n",
    "---\n",
    "> **Supported question types:** Fill-in-the-blank, Multiple choice, True/False, Short answer, Essay"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 1: Install Dependencies"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install pandas openpyxl --quiet\n",
    "print('✅ Dependencies ready')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 2: Upload Your .imscc File"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from google.colab import files\n",
    "import os\n",
    "\n",
    "print('📂 Please select your .imscc file...')\n",
    "uploaded = files.upload()\n",
    "\n",
    "imscc_files = [f for f in uploaded.keys() if f.endswith('.imscc')]\n",
    "\n",
    "if not imscc_files:\n",
    "    print('❌ No .imscc file detected. Please upload a file ending in .imscc')\n",
    "else:\n",
    "    IMSCC_FILE = imscc_files[0]\n",
    "    print(f'✅ Loaded: {IMSCC_FILE}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 3: Extract & Parse Questions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import zipfile\n",
    "import xml.etree.ElementTree as ET\n",
    "import json\n",
    "import pandas as pd\n",
    "import shutil\n",
    "import re\n",
    "from html.parser import HTMLParser\n",
    "\n",
    "# ── Config ──────────────────────────────────────────────────────────────────\n",
    "EXTRACT_DIR  = 'extracted_imscc'\n",
    "OUTPUT_JSON  = 'quiz_output.json'\n",
    "OUTPUT_CSV   = 'quiz_output.csv'\n",
    "OUTPUT_XLSX  = 'quiz_output.xlsx'\n",
    "\n",
    "# QTI namespace used in Schoology exports\n",
    "QTI_NS = 'http://www.imsglobal.org/xsd/ims_qtiasiv1p2'\n",
    "\n",
    "\n",
    "# ── Helpers ──────────────────────────────────────────────────────────────────\n",
    "class _HTMLStripper(HTMLParser):\n",
    "    \"\"\"Strip HTML tags from mattext content.\"\"\"\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        self.fed = []\n",
    "    def handle_data(self, d):\n",
    "        self.fed.append(d)\n",
    "    def get_text(self):\n",
    "        return ' '.join(self.fed).strip()\n",
    "\n",
    "def strip_html(html_text):\n",
    "    \"\"\"Remove HTML tags and normalise whitespace.\"\"\"\n",
    "    s = _HTMLStripper()\n",
    "    try:\n",
    "        s.feed(html_text)\n",
    "        text = s.get_text()\n",
    "    except Exception:\n",
    "        text = re.sub(r'<[^>]+>', ' ', html_text)\n",
    "    return re.sub(r'\\s+', ' ', text).strip()\n",
    "\n",
    "def ns(tag):\n",
    "    \"\"\"Return a namespace-qualified tag string.\"\"\"\n",
    "    return f'{{{QTI_NS}}}{tag}'\n",
    "\n",
    "def find_all(element, tag):\n",
    "    \"\"\"Find elements with OR without the QTI namespace.\"\"\"\n",
    "    results = element.findall(f'.//{ns(tag)}')\n",
    "    if not results:\n",
    "        results = element.findall(f'.//{tag}')\n",
    "    return results\n",
    "\n",
    "def extract_text(element):\n",
    "    \"\"\"Get all text from an element, stripping HTML.\"\"\"\n",
    "    raw = ''.join(element.itertext()).strip()\n",
    "    return strip_html(raw)\n",
    "\n",
    "\n",
    "# ── Question-type detection ──────────────────────────────────────────────────\n",
    "def detect_question_type(item):\n",
    "    text = ET.tostring(item, encoding='unicode').lower()\n",
    "    if 'multiple_choice' in text or 'choiceinteraction' in text:\n",
    "        return 'multiple_choice'\n",
    "    elif 'true_false' in text or 'truefalse' in text:   # ← fixed operator precedence bug\n",
    "        return 'true_false'\n",
    "    elif 'cc.fib' in text or 'render_fib' in text:\n",
    "        return 'fill_in_blank'\n",
    "    elif 'short_answer' in text:\n",
    "        return 'short_answer'\n",
    "    elif 'essay' in text:\n",
    "        return 'essay'\n",
    "    elif 'match' in text:\n",
    "        return 'matching'\n",
    "    else:\n",
    "        return 'unknown'\n",
    "\n",
    "\n",
    "# ── Core XML parser ──────────────────────────────────────────────────────────\n",
    "def parse_questions_from_xml(xml_file):\n",
    "    \"\"\"Parse a single QTI XML file and return a list of question dicts.\"\"\"\n",
    "    questions = []  # ← was missing the return statement in the original\n",
    "\n",
    "    try:\n",
    "        tree = ET.parse(xml_file)\n",
    "        root = tree.getroot()\n",
    "\n",
    "        # Grab the quiz title from the assessment element\n",
    "        assessment = root.find(f'{ns(\"assessment\")}') or root.find('assessment')\n",
    "        quiz_title = ''\n",
    "        if assessment is not None:\n",
    "            quiz_title = assessment.get('title', '')\n",
    "\n",
    "        items = find_all(root, 'item')\n",
    "        if not items:\n",
    "            print(f'  ⚠️  No <item> elements found in {os.path.basename(xml_file)}')\n",
    "            return questions\n",
    "\n",
    "        for item in items:\n",
    "            q_data = {\n",
    "                'quiz_title':      quiz_title,\n",
    "                'question_text':   '',\n",
    "                'type':            '',\n",
    "                'options':         [],\n",
    "                'correct_answers': []\n",
    "            }\n",
    "\n",
    "            q_data['type'] = detect_question_type(item)\n",
    "\n",
    "            # ── Question text (first mattext inside presentation) ────────────\n",
    "            for mat in find_all(item, 'mattext'):\n",
    "                text = extract_text(mat)\n",
    "                if text:\n",
    "                    q_data['question_text'] = text\n",
    "                    break  # use only the first (the prompt)\n",
    "\n",
    "            # ── Answer options (multiple-choice / true-false) ────────────────\n",
    "            for response in find_all(item, 'response_label'):\n",
    "                option_text = ''\n",
    "                for mat in find_all(response, 'mattext'):   # ← fixed typo 'matttext'\n",
    "                    option_text = extract_text(mat)\n",
    "                    break\n",
    "                if option_text:\n",
    "                    q_data['options'].append(option_text)\n",
    "\n",
    "            # ── Correct answer(s) ────────────────────────────────────────────\n",
    "            for condition in find_all(item, 'varequal'):\n",
    "                answer = extract_text(condition)\n",
    "                if answer:\n",
    "                    q_data['correct_answers'].append(answer)\n",
    "\n",
    "            if q_data['question_text']:\n",
    "                questions.append(q_data)\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f'  ❌ Failed to parse {xml_file}: {e}')\n",
    "\n",
    "    return questions   # ← THE critical fix\n",
    "\n",
    "\n",
    "# ── File helpers ──────────────────────────────────────────────────────────────\n",
    "def extract_imscc(file_path, output_folder):\n",
    "    if not zipfile.is_zipfile(file_path):\n",
    "        raise Exception('File is not a valid .imscc (zip-based) file')\n",
    "    if os.path.exists(output_folder):\n",
    "        shutil.rmtree(output_folder)   # clean slate on re-runs\n",
    "    with zipfile.ZipFile(file_path, 'r') as z:\n",
    "        z.extractall(output_folder)\n",
    "    print(f'✅ Extracted to {output_folder}/')\n",
    "\n",
    "def find_xml_files(root_dir):\n",
    "    xml_files = []\n",
    "    for root, dirs, files in os.walk(root_dir):\n",
    "        for f in files:\n",
    "            if f.endswith('.xml'):\n",
    "                xml_files.append(os.path.join(root, f))\n",
    "    return xml_files\n",
    "\n",
    "def process_all_questions(xml_files):\n",
    "    all_questions = []\n",
    "    for xml_file in xml_files:\n",
    "        print(f'  🔍 Parsing {os.path.basename(xml_file)}...')\n",
    "        qs = parse_questions_from_xml(xml_file)\n",
    "        print(f'     → {len(qs)} question(s) found')\n",
    "        all_questions.extend(qs)\n",
    "    return all_questions\n",
    "\n",
    "\n",
    "# ── Output builders ───────────────────────────────────────────────────────────\n",
    "def build_rows(questions):\n",
    "    \"\"\"Convert question dicts to flat rows suitable for CSV / Google Forms import.\"\"\"\n",
    "    rows = []\n",
    "    for q in questions:\n",
    "        row = {\n",
    "            'Quiz Title':      q.get('quiz_title', ''),\n",
    "            'Question':        q['question_text'],\n",
    "            'Type':            q['type'],\n",
    "            'Option 1':        '',\n",
    "            'Option 2':        '',\n",
    "            'Option 3':        '',\n",
    "            'Option 4':        '',\n",
    "            'Correct Answer':  ', '.join(q['correct_answers'])\n",
    "        }\n",
    "        for i, opt in enumerate(q['options'][:4]):\n",
    "            row[f'Option {i+1}'] = opt\n",
    "        rows.append(row)\n",
    "    return rows\n",
    "\n",
    "def save_outputs(questions):\n",
    "    # JSON (raw)\n",
    "    with open(OUTPUT_JSON, 'w', encoding='utf-8') as f:\n",
    "        json.dump(questions, f, indent=2, ensure_ascii=False)\n",
    "    print(f'✅ JSON  → {OUTPUT_JSON}')\n",
    "\n",
    "    rows = build_rows(questions)\n",
    "    df = pd.DataFrame(rows)\n",
    "\n",
    "    # CSV\n",
    "    df.to_csv(OUTPUT_CSV, index=False)\n",
    "    print(f'✅ CSV   → {OUTPUT_CSV}')\n",
    "\n",
    "    # Excel (easier to review before importing)\n",
    "    df.to_excel(OUTPUT_XLSX, index=False)\n",
    "    print(f'✅ Excel → {OUTPUT_XLSX}')\n",
    "\n",
    "    return df\n",
    "\n",
    "\n",
    "# ── MAIN ──────────────────────────────────────────────────────────────────────\n",
    "print('🚀 Starting conversion...\\n')\n",
    "\n",
    "extract_imscc(IMSCC_FILE, EXTRACT_DIR)\n",
    "\n",
    "xml_files = find_xml_files(EXTRACT_DIR)\n",
    "print(f'\\n📄 Found {len(xml_files)} XML file(s):\\n')\n",
    "for x in xml_files:\n",
    "    print(f'   {x}')\n",
    "\n",
    "print('\\n🔎 Parsing questions...')\n",
    "questions = process_all_questions(xml_files)\n",
    "print(f'\\n✅ Total questions extracted: {len(questions)}')\n",
    "\n",
    "print('\\n💾 Saving outputs...')\n",
    "df = save_outputs(questions)\n",
    "\n",
    "print('\\n📊 Preview:')\n",
    "pd.set_option('display.max_colwidth', 80)\n",
    "display(df)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 4: Download Output Files"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from google.colab import files\n",
    "\n",
    "print('⬇️  Downloading files...')\n",
    "files.download(OUTPUT_JSON)\n",
    "files.download(OUTPUT_CSV)\n",
    "files.download(OUTPUT_XLSX)\n",
    "print('✅ Done!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 📋 How to Import into Google Forms\n",
    "\n",
    "Google Forms does **not** support direct CSV quiz import natively, but there are two easy paths:\n",
    "\n",
    "### Option A — Google Forms Add-on (recommended)\n",
    "1. Open Google Forms → click the three-dot menu → **Add-ons**\n",
    "2. Search for **\"Import Questions\"** (by Awesome Table) or **\"FormRecycler\"**\n",
    "3. Follow the add-on instructions to import from the CSV/Excel file you downloaded\n",
    "\n",
    "### Option B — Google Apps Script (advanced, fully automated)\n",
    "Run the cell below to generate an Apps Script `.gs` file that creates the Google Form automatically when pasted into [script.google.com](https://script.google.com)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Generate Google Apps Script to auto-create the Form ──────────────────────\n",
    "import json\n",
    "\n",
    "with open(OUTPUT_JSON, 'r', encoding='utf-8') as f:\n",
    "    questions = json.load(f)\n",
    "\n",
    "# Group questions by quiz title\n",
    "from collections import defaultdict\n",
    "quizzes = defaultdict(list)\n",
    "for q in questions:\n",
    "    quizzes[q.get('quiz_title', 'Quiz')].append(q)\n",
    "\n",
    "def escape_js(s):\n",
    "    return s.replace('\\\\', '\\\\\\\\').replace('\"', '\\\\\"').replace('\\n', ' ').replace('\\r', '')\n",
    "\n",
    "script_lines = [\n",
    "    '// Auto-generated by Schoology → Google Forms Converter',\n",
    "    '// Paste this entire file into https://script.google.com and click Run → createQuizzes',\n",
    "    '',\n",
    "    'function createQuizzes() {',\n",
    "]\n",
    "\n",
    "for quiz_title, qs in quizzes.items():\n",
    "    safe_title = escape_js(quiz_title or 'Imported Quiz')\n",
    "    script_lines += [\n",
    "        f'  // ── {safe_title} ──────────────────────────',\n",
    "        f'  var form = FormApp.create(\"{safe_title}\");',\n",
    "         '  form.setIsQuiz(true);',\n",
    "    ]\n",
    "    for q in qs:\n",
    "        qt = q['type']\n",
    "        qtext = escape_js(q['question_text'])\n",
    "        correct = q['correct_answers'][0] if q['correct_answers'] else ''\n",
    "\n",
    "        if qt == 'fill_in_blank':\n",
    "            script_lines += [\n",
    "                f'  var item = form.addTextItem();',\n",
    "                f'  item.setTitle(\"{qtext}\");',\n",
    "                f'  var gradingItem = item.asTextItem();',\n",
    "                f'  // Correct answer: {escape_js(correct)}',\n",
    "            ]\n",
    "        elif qt in ('multiple_choice', 'true_false'):\n",
    "            options = q.get('options', [])\n",
    "            if not options and qt == 'true_false':\n",
    "                options = ['True', 'False']\n",
    "            opts_js = ', '.join([f'\"{escape_js(o)}\"' for o in options])\n",
    "            script_lines += [\n",
    "                f'  var item = form.addMultipleChoiceItem();',\n",
    "                f'  item.setTitle(\"{qtext}\");',\n",
    "            ]\n",
    "            if options:\n",
    "                script_lines.append(f'  item.setChoiceValues([{opts_js}]);')\n",
    "            if correct:\n",
    "                safe_correct = escape_js(correct)\n",
    "                script_lines += [\n",
    "                    f'  var correctChoice = item.createChoice(\"{safe_correct}\", true);',\n",
    "                    f'  // Note: set correct answer via Grading in Forms UI for full credit',\n",
    "                ]\n",
    "        else:  # short_answer, essay, unknown\n",
    "            script_lines += [\n",
    "                f'  var item = form.addParagraphTextItem();',\n",
    "                f'  item.setTitle(\"{qtext}\");',\n",
    "            ]\n",
    "\n",
    "    script_lines += [\n",
    "        f'  Logger.log(\"Created form: \" + form.getEditUrl());',\n",
    "        '',\n",
    "    ]\n",
    "\n",
    "script_lines.append('}')\n",
    "\n",
    "gs_output = '\\n'.join(script_lines)\n",
    "GS_FILE = 'create_google_forms.gs'\n",
    "with open(GS_FILE, 'w', encoding='utf-8') as f:\n",
    "    f.write(gs_output)\n",
    "\n",
    "print(f'✅ Apps Script generated: {GS_FILE}')\n",
    "print('\\n--- PREVIEW (first 40 lines) ---')\n",
    "print('\\n'.join(gs_output.splitlines()[:40]))"
   ]
  },
